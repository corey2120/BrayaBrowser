{
  "manifest_version": 2,
  "name": "Hello World Extension",
  "version": "1.0.0",
  "description": "A simple test extension that logs to console",

  "permissions": [
    "tabs",
    "storage",
    "<all_urls>"
  ],

  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],

  "browser_action": {
    "default_icon": "icon.png",
    "default_title": "Hello World!",
    "default_popup": "popup.html"
  }
}
